# Host port docker-compose publishes the app on.
PORT=3000

# How long a generated link stays alive, in seconds (default: 300 = 5 minutes).
LINK_TTL_SECONDS=300

# Maximum accepted image size, in megabytes.
MAX_UPLOAD_MB=10

# How often the expired-image sweeper runs, in seconds.
CLEANUP_INTERVAL_SECONDS=30

# Where uploaded images are stored on disk.
UPLOAD_DIR=./uploads

# Public origin used when building links, e.g. https://img.example.com
# Leave empty to derive it from the incoming request.
PUBLIC_BASE_URL=

# Build-time: GitHub repo shown in the header / star button.
VITE_GITHUB_REPO=HichemTab-tech/image-to-link
